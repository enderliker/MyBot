{
  "name": "discord-bot",
  "version": "1.0.0",
  "description": "A modular TypeScript Discord bot",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "postinstall": "node scripts/install-deps.js && tsc"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "libsodium-wrappers": "^0.8.4",
    "opusscript": "^0.0.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
